<mxfile host="Electron">
  <diagram id="rick-morty-arch" name="RickMorty – Clean Architecture">
    <mxGraphModel dx="900" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#333333;" value="Rick &amp; Morty — Clean Architecture" vertex="1">
          <mxGeometry x="150" y="10" width="600" height="30" as="geometry" />
        </mxCell>

        <!-- Presentation Layer -->
        <mxCell id="layer_pres" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;fontColor=#2B6B2B;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;arcSize=4;" value="&lt;b&gt;Presentation&lt;/b&gt;&lt;br&gt;&lt;br&gt;• MainTabView (3 tabs: Characters, Locations, Episodes)&lt;br&gt;• Views + ViewModels (MVVM)&lt;br&gt;• ViewState&amp;lt;T&amp;gt; state machine&lt;br&gt;• CachedAsyncImageView, StatusBadgeView&lt;br&gt;• LoadingView · ErrorView · EmptyStateView" vertex="1">
          <mxGeometry x="40" y="50" width="820" height="110" as="geometry" />
        </mxCell>

        <!-- Arrow label -->
        <mxCell id="arrow1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;" value="↓ depends on" vertex="1">
          <mxGeometry x="380" y="165" width="140" height="20" as="geometry" />
        </mxCell>

        <!-- Domain Layer -->
        <mxCell id="layer_domain" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D6B656;fontSize=12;fontColor=#7F4A00;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;arcSize=4;" value="&lt;b&gt;Domain&lt;/b&gt; (zero external dependencies)&lt;br&gt;&lt;br&gt;• Entities: Character, Location, Episode&lt;br&gt;• Repository Protocols (Character, Location, Episode)&lt;br&gt;• Use Cases: GetCharacters, GetCharacterDetail, GetLocations, GetEpisodes&lt;br&gt;• PagedResult&amp;lt;T&amp;gt;" vertex="1">
          <mxGeometry x="40" y="190" width="820" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow label -->
        <mxCell id="arrow2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;" value="↓ implemented by" vertex="1">
          <mxGeometry x="380" y="295" width="140" height="20" as="geometry" />
        </mxCell>

        <!-- Data Layer -->
        <mxCell id="layer_data" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;fontColor=#1A3D7F;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;arcSize=4;" value="&lt;b&gt;Data&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Repository Impls (Character, Location, Episode)&lt;br&gt;• DTOs + Mappers (DTO → Entity)&lt;br&gt;• APIEndpoint (REST paths for Rick &amp; Morty API)&lt;br&gt;• Network SPM: NetworkService + RetryingNetworkService" vertex="1">
          <mxGeometry x="40" y="320" width="820" height="90" as="geometry" />
        </mxCell>

        <!-- Core Layer -->
        <mxCell id="layer_core" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=12;fontColor=#4D1A7F;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;arcSize=4;" value="&lt;b&gt;Core&lt;/b&gt; (shared infrastructure)&lt;br&gt;&lt;br&gt;• DIContainer (dependency graph + ViewModel factories)&lt;br&gt;• AppRouter + CharacterRoute&lt;br&gt;• DesignSystem (DSColors, DSTypography, DSSpacing)&lt;br&gt;• ImageCacheManager (NSCache + disk) · AppGroupStore" vertex="1">
          <mxGeometry x="40" y="425" width="400" height="100" as="geometry" />
        </mxCell>

        <!-- Widget Extension -->
        <mxCell id="widget_ext" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;fontColor=#7A2929;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;arcSize=4;" value="&lt;b&gt;CharacterWidgetExtension&lt;/b&gt;&lt;br&gt;&lt;br&gt;• WidgetKit + App Intents&lt;br&gt;• ← → character navigation&lt;br&gt;• Reads from App Group container" vertex="1">
          <mxGeometry x="460" y="425" width="400" height="100" as="geometry" />
        </mxCell>

        <!-- External Systems -->
        <mxCell id="ext_api" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontColor=#333333;verticalAlign=middle;align=center;arcSize=4;" value="Rick &amp; Morty REST API&#xa;rickandmortyapi.com" vertex="1">
          <mxGeometry x="40" y="545" width="250" height="50" as="geometry" />
        </mxCell>

        <mxCell id="ext_spm" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontColor=#333333;verticalAlign=middle;align=center;arcSize=4;" value="Network SPM&#xa;(URLSession + retry)" vertex="1">
          <mxGeometry x="325" y="545" width="250" height="50" as="geometry" />
        </mxCell>

        <mxCell id="ext_appgroup" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontColor=#333333;verticalAlign=middle;align=center;arcSize=4;" value="App Group Container&#xa;app ↔ widget data sharing" vertex="1">
          <mxGeometry x="610" y="545" width="250" height="50" as="geometry" />
        </mxCell>

        <!-- Dependency hints (text only, no edges) -->
        <mxCell id="hint1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=10;fontColor=#999999;" value="Data → API via Network SPM" vertex="1">
          <mxGeometry x="40" y="605" width="250" height="20" as="geometry" />
        </mxCell>
        <mxCell id="hint2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=10;fontColor=#999999;" value="Core/AppGroupStore → shared container" vertex="1">
          <mxGeometry x="610" y="605" width="250" height="20" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
